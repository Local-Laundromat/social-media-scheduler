# Server Configuration
PORT=3000
AUTO_START_SCHEDULER=false
CRON_SCHEDULE=0 * * * *

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# AI Caption Generation (Optional)
OPENAI_API_KEY=your_openai_api_key_here

# Media Folder (your posts location)
MEDIA_FOLDER=/Users/aminatamansaray/Downloads/PK Property/Combined Social Media Posts

# Facebook OAuth Configuration (for user authentication)
# Create a Facebook App at: https://developers.facebook.com
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here
FACEBOOK_REDIRECT_URI=http://localhost:3000/auth/facebook/callback
INSTAGRAM_REDIRECT_URI=http://localhost:3000/auth/instagram/callback

# TikTok OAuth Configuration (for user authentication)
# Create a TikTok App at: https://developers.tiktok.com
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here
TIKTOK_REDIRECT_URI=http://localhost:3000/auth/tiktok/callback

# Legacy: Direct Facebook/Instagram credentials (optional - for backwards compatibility)
# Get these from: https://developers.facebook.com
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here
FACEBOOK_PAGE_ID=your_facebook_page_id_here
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id_here

# Public URL for Instagram (required for Instagram posting)
# For local development, use ngrok: https://ngrok.com
# For production, use your deployed server URL
PUBLIC_FILE_URL=http://localhost:3000/files

# Note: Instagram requires publicly accessible URLs for media
# Options:
# 1. Use ngrok for local testing: https://ngrok.com
# 2. Deploy to Railway/Render and use that URL
# 3. Upload files to S3/Cloudinary and use those URLs
